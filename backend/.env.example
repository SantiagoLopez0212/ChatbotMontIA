# MontIA Chatbot - Variables de Entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio Git.

# Servidor
PORT=3000

# Base de Datos (MySQL)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=tu_contraseña_aqui
DB_NAME=proyecto_chatbot
DB_PORT=3306

# Seguridad JWT - Cambia esto por una cadena larga y aleatoria
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga_y_aleatoria

# IA - Proveedor seleccionado automáticamente según disponibilidad:
#   1. Si OPENAI_API_KEY está definida → usa GPT-4o mini (recomendado para producción)
#   2. Si solo GEMINI_API_KEY está definida → usa Gemini Flash (plan gratuito con límites)
#   3. Si ninguna está definida → modo mock (respuestas ficticias para desarrollo)

# OpenAI GPT-4o mini (recomendado) — adquirir en https://platform.openai.com/
OPENAI_API_KEY=tu_clave_openai_aqui

# Google Gemini Flash (alternativa gratuita) — adquirir en https://aistudio.google.com/
GEMINI_API_KEY=tu_clave_gemini_aqui

# Correo (para recuperación de contraseña)
# Usa una "Contraseña de aplicación" de Gmail, no tu contraseña normal
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion_gmail
